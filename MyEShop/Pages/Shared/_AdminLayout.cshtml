<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - پنل مدیریت</title>

    <!-- Bootstrap 5 RTL -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" asp-append-version="true" />

    <!-- Bootstrap Icons -->
    <link href="~/lib/bootstrap/bootstrap-icons-1.13.1/bootstrap-icons.min.css" rel="stylesheet" asp-append-version="true" />

    <link href="~/css/Admin2.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/main.css" rel="stylesheet" asp-append-version="true" />

</head>
<body>

    <!-- Navbar -->
    <nav class="navbar-admin fixed-top">
        <div class="container-fluid d-flex justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <button class="menu-toggle" id="menuToggle">
                    <i class="bi bi-list"></i>
                </button>
                <a class="navbar-brand" href="/Admin">
                    <i class="bi bi-grid-3x3-gap-fill"></i> پنل مدیریت
                </a>
            </div>

            <div class="dropdown">
                <button class="btn btn-link text-white dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle fs-5"></i>
                    <span class="d-none d-md-inline">ادمین</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end text-center">
                    <li><a class="dropdown-item" href="/Admin/Profile"><i class="bi bi-person"></i> پروفایل</a></li>
                    <li><a class="dropdown-item" href="/Admin/Settings"><i class="bi bi-gear"></i> تنظیمات</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right"></i> خروج</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- سایدبار -->
    <div class="sidebar" id="sidebar">
        <ul class="sidebar-menu">
            <li>
                <a class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Index") == true ? "active" : "")" href="/Admin/Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>داشبورد</span>
                </a>
            </li>

            <!--  زیرگزینه محصولات -->
            <li>
                <div class="menu-item-dropdown" onclick="toggleSubMenu(this)">
                    <span>
                        <i class="bi bi-box-seam"></i>
                        <span>محصولات</span>
                    </span>
                    <i class="bi bi-chevron-down arrow"></i>
                </div>
                <ul class="sub-menu">
                    <li>
                        <a class="ms-3 @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Index") == true ? "active" : "")" href="/Admin/Products/Index">
                            <i class="bi bi-list"></i> لیست محصولات
                        </a>
                    </li>
                    <li>
                        <a class="ms-3 @(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Add") == true ? "active" : "")" href="/Admin/Products/Add">
                            <i class="bi bi-plus-circle"></i> اضافه کردن محصول
                        </a>
                    </li>
                </ul>
            </li>

            <li>
                <a class="menu-item" href="/Admin/Categories">
                    <i class="bi bi-tags"></i>
                    <span>دسته‌بندی‌ها</span>
                </a>
            </li>
            <li>
                <a class="menu-item" href="/Admin/Orders">
                    <i class="bi bi-cart-check"></i>
                    <span>سفارشات</span>
                </a>
            </li>
            <li>
                <a class="menu-item" href="/Admin/ManagmentUser">
                    <i class="bi bi-people"></i>
                    <span>کاربران</span>
                </a>
            </li>
            <li>
                <a class="menu-item" href="/Admin/Comments">
                    <i class="bi bi-chat-dots"></i>
                    <span>نظرات</span>
                </a>
            </li>
            <li>
                <a class="menu-item" href="/Admin/Settings">
                    <i class="bi bi-gear"></i>
                    <span>تنظیمات</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- محتوای اصلی main content -->
    <div class="main-content" id="mainContent">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/asmin.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>