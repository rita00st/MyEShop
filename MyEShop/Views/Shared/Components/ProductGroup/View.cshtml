@using MyEShop.Models.ViewModel.ProductGroup
@model IEnumerable<ProductGroupViewModel>
@{
    ViewData["Title"] = "View";
}

<div class="row justify-content-center">
    <div class="col">
        <ul class="list-group">
            @foreach (var item in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="/Group/@item.GroupId/@item.Name">@item.Name</a>
                    <span class="badge rounded-pill bg-primary">@item.ProductCount</span>
                </li>
            }
        </ul>
    </div>
</div>

