<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card login-card">
                <div class="row g-0">
                    <!-- سمت چپ: توضیحات فروشگاه -->
                    <div class="col-md-5 d-none  d-md-block">
                        <div class="card-side">
                            <div class="text-center">
                                <div class="icon-box mb-4">
                                    <i class="bi bi-bag-heart"></i>
                                </div>
                                <h2 class="side-title">
                                    به <span class="highlight">MyEShop</span><br />خوش آمدید
                                </h2>
                                <p class="side-text mt-3">
                                    بهترین و باکیفیت‌ترین محصولات را با قیمت‌های استثنایی از ما تهیه کنید.
                                    فروشگاهی برای همه سلیقه‌ها!
                                </p>
                            </div>
                            <ul class="feature-list">
                                <li><span class="dot"></span>بیش از ۱۰۰۰ محصول متنوع</li>
                                <li><span class="dot"></span>ارسال سریع و رایگان</li>
                                <li><span class="dot"></span>پشتیبانی ۲۴ ساعته</li>
                                <li><span class="dot"></span>تخفیف‌های ویژه برای اعضا</li>
                            </ul>
                        </div>
                    </div>

                    <!-- سمت راست: فرم‌ها -->
                    <div class="col-md-7">
                        <div class="card-body p-4 p-lg-5">
                            <!-- رادیوهای مخفی برای کنترل تب -->
                            <input type="radio" name="tab" id="tab-login" class="tab-radio" checked />
                            <input type="radio" name="tab" id="tab-register" class="tab-radio" />

                            <!-- نوار تب‌ها -->
                            <div class="tab-nav" role="tablist">
                                <label for="tab-login" class="tab-btn" role="tab">ورود به حساب</label>
                                <label for="tab-register" class="tab-btn" role="tab">ثبت‌نام</label>
                            </div>

                            <!-- فرم ورود -->
                            <div class="form-panel login-panel" id="form-login">
                                <h3 class="h4 fw-bold mb-1">خوش آمدید 👋</h3>
                                <p class="text-muted-light small mb-4">برای ورود، ایمیل و رمز عبور خود را وارد کنید.</p>
                                <form novalidate>
                                    <div class="form-floating mb-3">
                                        <input type="text" class="form-control" id="loginEmail" name="email" placeholder="name@example.com" autocomplete="email" inputmode="email">
                                        <label for="loginEmail">آدرس ایمیل</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input type="password" class="form-control" id="loginPassword" name="password" placeholder="رمز عبور" autocomplete="current-password">
                                        <label for="loginPassword">رمز عبور</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="remember" id="rememberMe">
                                            <label class="form-check-label" for="rememberMe">مرا به خاطر بسپار</label>
                                        </div>
                                        <a href="#" class="text-purple small">رمز عبور را فراموش کرده‌اید؟</a>
                                    </div>
                                    <button type="submit" class="btn btn-primary-custom w-100">
                                        <i class="bi bi-box-arrow-in-left me-2"></i>ورود به فروشگاه
                                    </button>
                                    <p class="text-center text-muted-light small mt-3">با ورود، با <a href="#">قوانین</a> و <a href="#">حریم خصوصی</a> موافقت می‌کنید.</p>
                                </form>
                                <p class="text-center mt-3">
                                    حساب ندارید؟ <label for="tab-register" class="switch-link">همین حالا ثبت‌نام کنید</label>
                                </p>
                            </div>

                            <!-- فرم ثبت‌نام -->
                            <div class="form-panel register-panel" id="form-register">
                                <h3 class="h4 fw-bold mb-1">ایجاد حساب کاربری 🚀</h3>
                                <p class="text-muted-light small mb-4">با ثبت‌نام، از تخفیف‌های ویژه و امکانات بیشتر بهره‌مند شوید.</p>
                                <form novalidate>
                                    <div class="form-floating mb-3">
                                        <input type="text" class="form-control" id="regName" name="name" placeholder="نام و نام خانوادگی" autocomplete="name">
                                        <label for="regName">نام و نام خانوادگی</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input type="text" class="form-control" id="regEmail" name="email" placeholder="name@example.com" autocomplete="email" inputmode="email">
                                        <label for="regEmail">آدرس ایمیل</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input type="password" class="form-control" id="regPassword" name="password" placeholder="حداقل ۸ کاراکتر" autocomplete="new-password">
                                        <label for="regPassword">رمز عبور</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input type="password" class="form-control" id="regConfirm" name="confirm" placeholder="رمز را دوباره وارد کنید" autocomplete="new-password">
                                        <label for="regConfirm">تکرار رمز عبور</label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" name="terms" id="termsCheck">
                                        <label class="form-check-label small" for="termsCheck">
                                            با <a href="#">قوانین و مقررات</a> و <a href="#">حریم خصوصی</a> فروشگاه موافقم
                                        </label>
                                        <span class="field-error text-danger small" style="display:none;"></span>
                                    </div>
                                    <button type="submit" class="btn btn-primary-custom w-100">
                                        <i class="bi bi-person-plus me-2"></i>ثبت‌نام در فروشگاه
                                    </button>
                                    <p class="text-center text-muted-light small mt-3">با ثبت‌نام، اولین تخفیف خود را دریافت کنید!</p>
                                </form>
                                <p class="text-center mt-3">
                                    قبلاً ثبت‌نام کرده‌اید؟ <label for="tab-login" class="switch-link">وارد شوید</label>
                                </p>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <p class="text-center text-muted-light small mt-3">© ۲۰۲۶ — فروشگاه اینترنتی MyEShop</p>
        </div>
    </div>
</div>