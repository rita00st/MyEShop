<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/bootstrap/bootstrap-icons-1.13.1/bootstrap-icons.min.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyEShop.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-gradient-purple shadow-lg fixed-top">
            <div class="container-fluid">
                <!-- لوگو و برند -->
                <a class="navbar-brand fw-bold fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop"></i>
                    <span class="text-golden">My</span>EShop
                </a>

                <!-- دکمه منوی موبایل -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- منوی اصلی -->
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill"></i> خانه
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="ContactUs">
                                <i class="bi bi-envelope-fill"></i> تماس با ما
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle nav-link-custom" href="#" id="categoriesDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-grid-fill"></i> دسته‌بندی‌ها
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3" aria-labelledby="categoriesDropdown">
                                <li><partial name="Partials/_Group"  /></li>
                            </ul>
                        </li>
                    </ul>

                    <!-- جستجو -->
                    <form class="d-flex mx-3 position-relative" role="search">
                        <input class="form-control search-input rounded-pill px-4" type="search"
                               placeholder="جستجوی محصول..." aria-label="Search">
                        <button class="btn btn-search rounded-pill" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <!-- بخش کاربری و سبد خرید -->
                    <ul class="navbar-nav ms-auto align-items-center">
                        <!-- سبد خرید -->
                        <li class="nav-item me-2">
                            <a class="nav-link position-relative cart-link" asp-controller="Home" asp-action="ShowCart" >
                                <i class="bi bi-cart3 fs-4"></i>
                                <span class="cart-badge badge bg-danger rounded-pill">3</span>
                            </a>
                        </li>

                        <!-- احراز هویت -->
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown ">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#"
                                   id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="user-avatar">
                                        <i class="bi bi-person-circle fs-4"></i>
                                    </div>
                                    <span class="d-none d-lg-inline text-white">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 text-center rounded-3 py-2"
                                    aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" href="/Account/Profile">
                                            <i class="bi bi-person me-2"></i> پروفایل
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/Account/Orders">
                                            <i class="bi bi-box-seam me-2"></i> سفارشات
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-area="" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> خروج
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3 me-2"
                                   asp-area="" asp-controller="Account" asp-action="Rejester">
                                    ثبت‌نام
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-golden btn-sm rounded-pill px-4"
                                   asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-left me-1"></i> ورود
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>


    <div class="container mt-5 pt-5">
        <div class="row">
            <div class="col-md-3">
                @await Component.InvokeAsync("ProductGroup")
            </div>
            <div class="col-md-9">
                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MyEShop - <a asp-area="" asp-controller="Home" asp-action="ContactUs">نماس با ما</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
